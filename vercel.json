{
  "version": 2,
  "buildCommand": "vite build -c vite.config.vercel.ts && tsx scripts/generate-icons.ts",
  "outputDirectory": "dist/client",
  "functions": {
    "api/index.ts": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
