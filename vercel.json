{
  "version": 2,
  "buildCommand": "vite build -c vite.config.vercel.ts",
  "outputDirectory": "dist/client",
  "functions": {
    "api/ai/generate-plan.ts": { "memory": 256, "maxDuration": 30 },
    "api/ai/chat.ts": { "memory": 256, "maxDuration": 30 },
    "api/ai/chat/stream.ts": { "memory": 256, "maxDuration": 30 },
    "api/ai/scan-food.ts": { "memory": 256, "maxDuration": 30 },
    "api/dashboard/stats.ts": { "memory": 256, "maxDuration": 15 },
    "api/auth/register.ts": { "memory": 128, "maxDuration": 10 },
    "api/auth/login.ts": { "memory": 128, "maxDuration": 10 }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
