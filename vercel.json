{
  "version": 2,
  "buildCommand": "tsx scripts/generate-icons.ts && vite build -c vite.config.vercel.ts && tsx scripts/generate-icons.ts",
  "outputDirectory": "dist/client",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
